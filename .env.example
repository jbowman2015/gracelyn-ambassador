# ── Policy thresholds (Dr. Flippen confirms) ──
# APPROVAL_MODE=AUTO confirmed 2026-07-13: the program already auto-approves ambassadors
# once they sign compliance documents and complete training, so there is no MANUAL phase to
# start in. ACTIVE_AMBASSADOR_THRESHOLD_ALERT/_AUTO are the design doc's Phase-1-to-2 switch
# thresholds and don't gate anything while APPROVAL_MODE stays AUTO from day one.
APPROVAL_MODE=AUTO
ACTIVE_AMBASSADOR_THRESHOLD_ALERT=800
ACTIVE_AMBASSADOR_THRESHOLD_AUTO=1000
NON_REFERRAL_DAYS_THRESHOLD=90
DORMANT_DAYS_THRESHOLD=30
VIP_HIGH_PCT_SMALL=2.5
VIP_STD_PCT_SMALL=5
VIP_HIGH_PCT_LARGE=0.5
VIP_STD_PCT_LARGE=2.5
VIP_POPULATION_THRESHOLD=10000
VIP_AUDIT_TOLERANCE_PCT=10
STORY_BUFFER_MINIMUM=4
WEEKLY_BATCH_SIZE=100
MISSION_KEYWORDS=
SLA_TIER2_FIRST_RESPONSE_HOURS=24
SLA_VIP_FIRST_RESPONSE_HOURS=4
SLA_TIER2_RESOLUTION_HOURS=72
SLA_VIP_RESOLUTION_HOURS=24
META_DAILY_SPEND_THRESHOLD=
GOOGLE_DAILY_SPEND_THRESHOLD=

# ── Agent 0 — Research & Intelligence ──
# Behaviour / policy
AGENT0_AUDIENCE_CONFIG=
VIP_PROSPECT_SCORE_THRESHOLD=60
AGENT0_RUN_MODE=WEEKLY
ANTHROPIC_MODEL=claude-sonnet-4-20250514
# NOTE: PROSPECTS_MODULE_API_NAME (above) = Ambassador_Leads (existing custom module).
# Agent 0's VIP-prospect scoring fields must be created ON that module before a live
# run; Agent 0 verifies them live at Step 4 and alerts Jessica if any are missing.
# Admin alert recipient (replaces the design doc's "Parmeet" role). Set to
# jessica.bowman@gracelyn.edu. JESSICA_ALERT_EMAIL / PARMEET_ALERT_EMAIL aliases accepted.
ADMIN_ALERT_EMAIL=
# Optional: POST admin alert emails to this Make.com webhook for delivery
MAKE_ADMIN_ALERT_WEBHOOK_URL=
# Phase-2 enrichment — stored, dormant until the Day 60 review
APOLLO_API_KEY=
HUNTER_API_KEY=

# ── Agent 2 — Onboarding ──
# Zoho Mail send credentials (Agent 2 is the first agent to send mail)
ZOHO_MAIL_ACCOUNT_ID=
# AMBASSADOR_MAIL_FROM_ADDRESS is set once, below, in the Agent 3 block — shared
# canonical name with Agent 2 (JP1-T349, resolved 2026-07-13). Do not re-add
# ZOHO_MAIL_FROM_ADDRESS here.
# Behaviour / policy
AMBASSADORS_MODULE_API_NAME=Ambassadors
COMBINED_FORM_ID=
WINBACK_SURVEY_FORM_ID=
ZOHO_FORMS_BASE_URL=
WINBACK_WALKTHROUGH_VIDEO_URL=
AUTO_APPROVE_CRITERIA_VERSION=v2.0
# Make.com webhooks specific to Agent 2 (not in the shared list above)
MAKE_WINBACK_SURVEY_WEBHOOK=
MAKE_AGENT2_ERROR_WEBHOOK=
# NOTE: AMBASSADORS_MODULE_API_NAME confirmed live 2026-07-10 = "Ambassadors" (CustomModule37).
# 23 fields were missing and created live for Agent 2 — see functions/agent2/README.md for
# the full reconciliation, including the three field names that had to be shortened to fit
# Zoho's 25-char field-label limit (Motivation_Response, Auto_Approve_Version,
# Compliance_Form_Version) and Ambassador_Role_Category being created as text, not picklist.

# ── Agent 3 — Engagement ──
# NOTE: AMBASSADORS_MODULE_API_NAME / REFERRALS_MODULE_API_NAME (above) confirmed
# live 2026-07-10 as Ambassadors / Referrals. Sixteen new fields were created live
# on Ambassadors for the sprint/engagement/VIP-tier system; see
# functions/agent3/manifest.js AMBASSADOR_FIELDS and DEPLOY.md for the full map.
# AMBASSADOR_MAIL_FROM_ADDRESS: canonical send-from address, shared with Agent 2
# above (JP1-T349, resolved 2026-07-13 — Agent 2 previously used the alias
# ZOHO_MAIL_FROM_ADDRESS; both now read this one name).
AMBASSADOR_MAIL_FROM_ADDRESS=ambassadors@gracelyn.edu
SPRINT_GRADUATION_DAYS=28
MAKE_AGENT3_ERROR_WEBHOOK=
# Fired by monthlyVipRecalculation on completion; feeds Agent 4's post-recalculation
# audit (HARD STOP #3) via Make.com Scenario 3 — code side resolved 2026-07-13, the
# Make.com scenario itself still needs building. See functions/agent3/DEPLOY.md.
MAKE_AGENT3_RECALC_COMPLETE_WEBHOOK=

# ── Agent 5 — Ambassador Support ──
# WordPress REST path Agent 5 calls to verify a portal session token and
# extract the ambassador's email (design doc names no concrete endpoint —
# build-time seam; confirm the real path with Parmeet before deploying).
WORDPRESS_SESSION_VERIFY_PATH=/wp-json/gracelyn/v1/verify-session
# NOTE: SUPPORT_TICKETS_MODULE_API_NAME (above) confirmed live 2026-07-10 =
# "Support_Tickets" (CustomModule42) — all nine SLA fields Agent 4 also depends
# on already existed with matching api_names, data types, and picklist values;
# no fields created. See functions/agent5/README.md for the full reconciliation.

# ── Agent 6 — Story Content Intake ──
# Daily buffer-monitoring Catalyst job only; story intake itself is a native
# Zoho Flow (not on Catalyst) — see functions/agent6/README.md.
# WORKDRIVE_FOLDER_05_ID, STORY_BUFFER_MINIMUM, PARMEET_ALERT_EMAIL, and
# AMBASSADORS_MODULE_API_NAME (all above) are shared with Agent 3 — confirm
# WORKDRIVE_FOLDER_05_ID matches Agent 3's value exactly before deploy.
STORY_INTAKE_FORM_URL=
MAKE_BUFFER_ALERT_WEBHOOK=
ZOHO_FLOW_ID=
# NOTE: ZOHO_CRM_* (above) is OPTIONAL for Agent 6 — used only for the
# best-effort "used file this week" exclusion in the buffer count (design
# §6). The design doc's own credential tables never list CRM for Agent 6;
# the job degrades gracefully (counts every file) when these are unset.

# ── Agent 1C — Paid Advertising ──
AMBASSADOR_ANALYTICS_DAILY_SPEND_VIEW=DailySpendLog
GOOGLE_ADS_API_VERSION=v16
# NOTE: AD_CAMPAIGN_LOG_MODULE_API_NAME (above) — ✅ created live 2026-07-13, set to
# Ad_Campaign_Logs (Zoho auto-generated the plural form from the module label — not
# "Ad_Campaign_Log"). 25 fields created matching functions/agent1C/manifest.js LOG_FIELDS
# exactly (verified via getFields, zero divergence). See functions/agent1C/DEPLOY.md.
# NOTE: PROSPECT_READ_FIELDS Agent 1C reads (Role_Category, Motivation_Tag,
# VIP_Prospect_Score) are Agent 0's LIVE field names on Ambassador_Leads, not the
# Agent 1C design doc's stale names (Ambassador_Role_Category, Motivation_Hypothesis,
# VIP_Score) — see functions/agent1C/README.md.
# KILL SWITCH: checkSpendConfirmation pauses ALL campaigns on both platforms if
# COORDINATOR_ALERT_EMAIL has not confirmed daily spend by 10:00 AM CST.
